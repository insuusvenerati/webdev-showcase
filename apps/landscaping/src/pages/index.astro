---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Oak & Ivy | Landscape Design & Garden Architecture">
  <!-- Navigation Header -->
  <header class="header">
    <div class="nav-container">
      <a href="#" class="logo">
        <span class="logo-icon">🌿</span>
        <span class="logo-text">Oak & Ivy</span>
      </a>
      <nav class="nav-links">
        <a href="#services">Services</a>
        <a href="#portfolio">Portfolio</a>
        <a href="#testimonials">Testimonials</a>
        <a href="#contact" class="btn btn-secondary">Request Consultation</a>
      </nav>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="hero" style="background-image: linear-gradient(rgba(28, 39, 26, 0.5), rgba(28, 39, 26, 0.5)), url('/images/hero.png');">
    <div class="hero-container">
      <span class="hero-tag">LANDSCAPE ARCHITECTURE & DESIGN</span>
      <h1 class="hero-title">Sculpting nature, enhancing living.</h1>
      <p class="hero-desc">
        We design and build bespoke outdoor living spaces, blending natural stone, native flora, and structured architectural lines.
      </p>
      <div class="hero-actions">
        <a href="#contact" class="btn btn-secondary">Book a Consultation</a>
        <a href="#portfolio" class="btn btn-outline">Explore Our Work</a>
      </div>
    </div>
  </section>

  <!-- About Short Introduction -->
  <section class="intro">
    <div class="intro-container">
      <div class="intro-header">
        <span class="section-tag">Philosophy</span>
        <h2>A thoughtful approach to outdoor architecture</h2>
        <div class="divider"></div>
      </div>
      <div class="intro-content">
        <p>
          We believe a garden is an extension of the home. By carefully selecting native species that thrive in the local climate and balancing them with high-end stonework, we create sustainable, beautiful ecosystems that mature gracefully over time.
        </p>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="services">
    <div class="services-container">
      <div class="section-header">
        <span class="section-tag">Expertise</span>
        <h2>Our Services</h2>
        <div class="divider"></div>
      </div>

      <div class="services-grid">
        <!-- Service 1 -->
        <div class="service-card">
          <div class="service-icon">📐</div>
          <h3>Garden Design & Architecture</h3>
          <p>Complete master planning including site analysis, planting layouts, lighting design, and 3D architectural mockups for backyards and estates.</p>
        </div>

        <!-- Service 2 -->
        <div class="service-card">
          <div class="service-icon">🪨</div>
          <h3>Luxury Hardscaping</h3>
          <p>Custom stone paved pathways, retaining walls, flagstone patios, custom masonry fire pits, and outdoor kitchens built to last generations.</p>
        </div>

        <!-- Service 3 -->
        <div class="service-card">
          <div class="service-icon">🌳</div>
          <h3>Estate Care & Horticulture</h3>
          <p>Professional seasonal pruning, plant nutrition, organic soil remediation, and preservation management of specimen trees and shrubs.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Portfolio Section -->
  <section id="portfolio" class="portfolio">
    <div class="portfolio-container">
      <div class="section-header">
        <span class="section-tag">Selected Works</span>
        <h2>Our Portfolio</h2>
        <div class="divider"></div>
      </div>

      <div class="portfolio-grid">
        <!-- Project 1 -->
        <div class="portfolio-card">
          <div class="portfolio-image-wrapper">
            <img src="/images/portfolio_walkway.png" alt="Custom stone pathway winding through lush lavender and hydrangeas" />
          </div>
          <div class="portfolio-details">
            <span class="project-category">Hardscaping & Garden Design</span>
            <h3>The Lavender Walkway</h3>
            <p>A structured flagstone pathway integrated with soft drift plantings of lavender, hydrangeas, and low boxwoods, leading to a secluded reading nook.</p>
          </div>
        </div>

        <!-- Project 2 -->
        <div class="portfolio-card">
          <div class="portfolio-image-wrapper">
            <img src="/images/portfolio_garden.png" alt="Meticulously designed garden bed with dark mulch, slate boulder, and boxwood shrubs" />
          </div>
          <div class="portfolio-details">
            <span class="project-category">Specimen Planting & Mulching</span>
            <h3>Slate Rock Garden Bed</h3>
            <p>High-contrast organic garden bed utilizing natural slate boulders as structural accents, surrounded by layered salvia and cloud-pruned boxwoods.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section id="testimonials" class="testimonials">
    <div class="testimonials-container">
      <div class="section-header">
        <span class="section-tag">Client Stories</span>
        <h2>Reflections</h2>
        <div class="divider"></div>
      </div>

      <div class="testimonials-grid">
        <div class="testimonial-card">
          <p class="testimonial-text">
            "Oak & Ivy completely transformed our steep, unusable backyard slope into a multi-tiered stone patio with lush, easy-to-maintain garden beds. The craftsmanship of the masonry is absolutely stunning."
          </p>
          <div class="testimonial-author">
            <span class="author-name">Emily & Arthur K.</span>
            <span class="author-location">High Park Resident</span>
          </div>
        </div>

        <div class="testimonial-card">
          <p class="testimonial-text">
            "Their attention to detail and knowledge of botany is impressive. They didn't just plant flowers; they created a balanced ecosystem that hosts birds and butterflies. We could not be happier."
          </p>
          <div class="testimonial-author">
            <span class="author-name">David L.</span>
            <span class="author-location">Rosedale Homeowner</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Consultation Form Section -->
  <section id="contact" class="contact">
    <div class="contact-container">
      <div class="contact-card">
        <div class="contact-grid">
          <div class="contact-intro">
            <span class="section-tag">Get in Touch</span>
            <h2>Let's plan your garden transformation</h2>
            <div class="divider align-left"></div>
            <p>
              Every project begins with a conversation. We will visit your property to evaluate soil conditions, sunlight exposure, and space dynamics to draft an initial concept.
            </p>
            <div class="contact-methods">
              <div class="method-item">
                <span class="method-icon">📞</span>
                <div>
                  <h4>Call Us</h4>
                  <p>+1 (647) 555-0144</p>
                </div>
              </div>
              <div class="method-item">
                <span class="method-icon">📍</span>
                <div>
                  <h4>Office Address</h4>
                  <p>720 Broadview Ave, Toronto, ON M4K 2P1</p>
                </div>
              </div>
            </div>
          </div>

          <form class="consultation-form" onsubmit="return false;">
            <h3>Request Consultation</h3>
            <div class="form-group">
              <label for="name">Your Name</label>
              <input type="text" id="name" name="name" required placeholder="Elena Rostova" />
            </div>

            <div class="form-group">
              <label for="email">Email Address</label>
              <input type="email" id="email" name="email" required placeholder="elena@example.com" />
            </div>

            <div class="form-group">
              <label for="phone">Phone Number</label>
              <input type="tel" id="phone" name="phone" required placeholder="(647) 555-0144" />
            </div>

            <div class="form-group">
              <label for="scope">Project Scope</label>
              <select id="scope" name="scope">
                <option value="complete">Complete Landscape Redesign</option>
                <option value="hardscape">Stonework & Hardscaping Only</option>
                <option value="care">Horticulture & Seasonal Care</option>
              </select>
            </div>

            <div class="form-group">
              <label for="details">Project Details</label>
              <textarea id="details" name="details" rows="4" required placeholder="Describe your outdoor space size, goals, and any reference styles you love..."></textarea>
            </div>

            <button type="submit" class="btn btn-primary btn-full">Submit Request</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-container">
      <div class="footer-brand">
        <h3>Oak & Ivy</h3>
        <p>Sculpting nature, enhancing living.</p>
      </div>
      <nav class="footer-links">
        <a href="#services">Services</a>
        <a href="#portfolio">Portfolio</a>
        <a href="#testimonials">Testimonials</a>
        <a href="#contact">Contact</a>
      </nav>
      <div class="footer-bottom">
        <p>&copy; 2026 Oak & Ivy Landscaping. All rights reserved. Statically built, zero JS.</p>
      </div>
    </div>
  </footer>
</Layout>

<style>
  /* Header & Navigation */
  .header {
    background-color: rgba(245, 247, 244, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .nav-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.25rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .logo-icon {
    font-size: 1.6rem;
  }
  .logo-text {
    font-family: var(--font-serif);
    font-weight: 800;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .nav-links a:not(.btn) {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-muted);
  }
  .nav-links a:not(.btn):hover {
    color: var(--color-primary);
  }

  /* Buttons */
  .btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border-radius: var(--border-radius);
    font-size: 0.9rem;
    font-weight: 600;
    text-align: center;
    border: 1px solid transparent;
  }
  .btn-primary {
    background-color: var(--color-primary);
    color: var(--color-white);
  }
  .btn-primary:hover {
    background-color: var(--color-primary-hover);
  }
  .btn-secondary {
    background-color: var(--color-secondary);
    color: var(--color-text);
  }
  .btn-secondary:hover {
    filter: brightness(0.95);
  }
  .btn-outline {
    border-color: var(--color-border);
    color: var(--color-white);
  }
  .btn-outline:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }
  .btn-full {
    display: block;
    width: 100%;
  }

  /* Hero Section */
  .hero {
    height: 80vh;
    min-height: 550px;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    padding: 2rem;
  }
  .hero-container {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    color: var(--color-white);
  }
  .hero-tag {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    color: var(--color-stone);
    margin-bottom: 1.5rem;
    display: block;
  }
  .hero-title {
    font-size: clamp(2.5rem, 5.5vw, 4.25rem);
    margin-bottom: 1.5rem;
    font-weight: 700;
  }
  .hero-desc {
    font-size: 1.25rem;
    max-width: 650px;
    margin: 0 auto 3rem auto;
    color: var(--color-stone);
    line-height: 1.5;
  }
  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  /* Section Styles */
  .section-tag {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
    display: inline-block;
  }
  .divider {
    height: 3px;
    width: 50px;
    background-color: var(--color-secondary);
    margin: 1.25rem auto 0 auto;
    border-radius: 2px;
  }
  .divider.align-left {
    margin-left: 0;
  }

  /* Intro Section */
  .intro {
    padding: 7rem 2rem;
    background-color: var(--color-white);
    text-align: center;
  }
  .intro-container {
    max-width: 800px;
    margin: 0 auto;
  }
  .intro-header h2 {
    font-size: 2.25rem;
  }
  .intro-content {
    margin-top: 3rem;
  }
  .intro-content p {
    font-size: 1.25rem;
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  /* Services Section */
  .services {
    padding: 7rem 2rem;
    background-color: var(--color-bg-alt);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .services-container {
    max-width: var(--max-width);
    margin: 0 auto;
  }
  .services-container .section-header {
    text-align: center;
    margin-bottom: 4.5rem;
  }
  .services-container h2 {
    font-size: 2.5rem;
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
  }
  .service-card {
    background-color: var(--color-white);
    padding: 3.5rem 2.5rem;
    border-radius: var(--border-radius);
    border: 1px solid var(--color-border);
    transition: var(--transition-smooth);
    box-shadow: var(--shadow-sm);
  }
  .service-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-primary);
  }
  .service-icon {
    font-size: 2.75rem;
    margin-bottom: 1.5rem;
  }
  .service-card h3 {
    font-size: 1.4rem;
    margin-bottom: 1rem;
    font-weight: 700;
  }
  .service-card p {
    font-size: 0.95rem;
  }

  /* Portfolio Section */
  .portfolio {
    padding: 8rem 2rem;
    background-color: var(--color-white);
  }
  .portfolio-container {
    max-width: var(--max-width);
    margin: 0 auto;
  }
  .portfolio-container .section-header {
    text-align: center;
    margin-bottom: 5rem;
  }
  .portfolio-container h2 {
    font-size: 2.5rem;
  }
  .portfolio-grid {
    display: flex;
    flex-direction: column;
    gap: 5rem;
  }
  .portfolio-card {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 4.5rem;
    align-items: center;
  }
  .portfolio-card:nth-child(even) {
    grid-template-columns: 0.9fr 1.1fr;
  }
  .portfolio-card:nth-child(even) .portfolio-image-wrapper {
    grid-column: 2;
  }
  .portfolio-card:nth-child(even) .portfolio-details {
    grid-column: 1;
    grid-row: 1;
  }
  .portfolio-image-wrapper {
    overflow: hidden;
    border-radius: var(--border-radius-lg);
    box-shadow: var(--shadow-md);
  }
  .portfolio-image-wrapper img {
    width: 100%;
    height: 420px;
    object-fit: cover;
    transition: var(--transition-smooth);
  }
  .portfolio-card:hover .portfolio-image-wrapper img {
    transform: scale(1.02);
  }
  .portfolio-details {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .project-category {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-secondary);
    margin-bottom: 0.75rem;
  }
  .portfolio-details h3 {
    font-size: 2rem;
    margin-bottom: 1.25rem;
    font-weight: 700;
  }
  .portfolio-details p {
    font-size: 1.05rem;
    line-height: 1.7;
  }

  /* Testimonials Section */
  .testimonials {
    padding: 8rem 2rem;
    background-color: var(--color-bg-alt);
    border-top: 1px solid var(--color-border);
  }
  .testimonials-container {
    max-width: var(--max-width);
    margin: 0 auto;
  }
  .testimonials-container .section-header {
    text-align: center;
    margin-bottom: 4.5rem;
  }
  .testimonials-container h2 {
    font-size: 2.5rem;
  }
  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3.5rem;
    max-width: 950px;
    margin: 0 auto;
  }
  .testimonial-card {
    background-color: var(--color-white);
    padding: 3.5rem;
    border-radius: var(--border-radius);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }
  .testimonial-text {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-style: italic;
    line-height: 1.65;
    margin-bottom: 2rem;
    color: var(--color-text);
  }
  .testimonial-author {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .author-name {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-primary);
  }
  .author-location {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  /* Contact / Consultation Section */
  .contact {
    padding: 8rem 2rem;
    background-color: var(--color-white);
  }
  .contact-container {
    max-width: var(--max-width);
    margin: 0 auto;
  }
  .contact-card {
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    padding: 5rem;
    box-shadow: var(--shadow-lg);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }
  .contact-intro h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }
  .contact-intro p {
    font-size: 1.1rem;
    margin-bottom: 3.5rem;
  }
  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .method-item {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }
  .method-icon {
    font-size: 1.75rem;
    line-height: 1;
    background-color: var(--color-white);
    padding: 0.75rem;
    border-radius: 50%;
    border: 1px solid var(--color-border);
  }
  .method-item h4 {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }
  .method-item p {
    font-size: 0.95rem;
  }

  /* Consultation Form */
  .consultation-form {
    background-color: var(--color-white);
    padding: 3.5rem;
    border-radius: var(--border-radius);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-md);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .consultation-form h3 {
    font-size: 1.6rem;
    margin-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-bg-alt);
    padding-bottom: 0.75rem;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .form-group label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text);
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 0.85rem 1rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    border: 1px solid var(--color-border);
    background-color: var(--color-bg);
    color: var(--color-text);
    border-radius: 6px;
    transition: var(--transition-smooth);
    width: 100%;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    background-color: var(--color-white);
    box-shadow: 0 0 0 3px rgba(44, 87, 56, 0.1);
  }

  /* Footer */
  .footer {
    background-color: var(--color-text);
    color: var(--color-white);
    padding: 5rem 2rem 3rem 2rem;
  }
  .footer-container {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 4rem;
  }
  .footer-brand h3 {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    margin-bottom: 1rem;
  }
  .footer-brand p {
    color: var(--color-secondary);
    font-size: 1rem;
  }
  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-end;
  }
  .footer-links a {
    color: var(--color-stone);
    font-size: 0.95rem;
    font-weight: 600;
  }
  .footer-links a:hover {
    color: var(--color-secondary);
  }
  .footer-bottom {
    grid-column: 1 / -1;
    border-top: 1px solid #2C392C;
    padding-top: 2rem;
    margin-top: 1rem;
    text-align: center;
  }
  .footer-bottom p {
    color: var(--color-secondary);
    font-size: 0.85rem;
    opacity: 0.7;
  }

  /* Responsive Design */
  @media (max-width: 992px) {
    .services-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .portfolio-card,
    .portfolio-card:nth-child(even) {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .portfolio-card:nth-child(even) .portfolio-image-wrapper {
      grid-column: 1;
    }
    .portfolio-card:nth-child(even) .portfolio-details {
      grid-column: 1;
    }
    .portfolio-image-wrapper img {
      height: 300px;
    }
    .testimonials-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .contact-card {
      padding: 3rem 2rem;
    }
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
    .consultation-form {
      padding: 2.5rem 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .nav-container {
      flex-direction: column;
      gap: 1.25rem;
      padding: 1.25rem 1rem;
    }
    .nav-links {
      flex-wrap: wrap;
      justify-content: center;
      gap: 1.25rem;
    }
    .footer-container {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }
    .footer-links {
      align-items: center;
    }
  }
</style>
