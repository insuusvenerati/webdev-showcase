---
interface Props { class?: string }
const { class: className = '' } = Astro.props;
---
<div aria-hidden="true" class={`pointer-events-none absolute inset-0 overflow-hidden ${className}`}>
	<div
		class="absolute left-[35%] top-0 h-[40rem] w-[40rem] -translate-x-1/2 -translate-y-1/3 rounded-full opacity-20 blur-[100px] dark:opacity-30"
		style="background: radial-gradient(closest-side, oklch(0.55 0.25 300 / 0.8), transparent);"
	></div>
	<div
		class="absolute left-[65%] top-12 h-[35rem] w-[35rem] -translate-x-1/2 -translate-y-1/3 rounded-full opacity-20 blur-[100px] dark:opacity-25"
		style="background: radial-gradient(closest-side, oklch(0.65 0.18 190 / 0.7), transparent);"
	></div>
</div>
