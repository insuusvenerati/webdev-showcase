---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Apex Barber Co. | Premium Grooming & Haircuts">
  <!-- Navigation Header -->
  <header class="header">
    <div class="nav-container">
      <a href="#" class="logo">
        <span class="logo-text">APEX BARBER CO.</span>
      </a>
      <nav class="nav-links">
        <a href="#services">Services</a>
        <a href="#lookbook">Lookbook</a>
        <a href="#barbers">Barbers</a>
        <a href="#contact" class="btn btn-primary">Book Appointment</a>
      </nav>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="hero" style="background-image: linear-gradient(rgba(10, 10, 10, 0.75), rgba(10, 10, 10, 0.75)), url('/images/hero.png');">
    <div class="hero-container">
      <span class="hero-tag">EST. 2026 / TORONTO</span>
      <h1 class="hero-title">PRECISION GROOMING FOR THE MODERN MAN</h1>
      <p class="hero-desc">
        A premium barbershop experience blending traditional craft with modern styling. Located in the historic distillery district.
      </p>
      <div class="hero-actions">
        <a href="#services" class="btn btn-primary">View Services & Pricing</a>
        <a href="#contact" class="btn btn-outline">Location & Hours</a>
      </div>
    </div>
  </section>

  <!-- Info Strip -->
  <section class="info-strip">
    <div class="info-strip-container">
      <div class="info-item">
        <span class="info-label">WALK-INS WELCOME</span>
        <span class="info-value">Subject to Availability</span>
      </div>
      <div class="info-divider"></div>
      <div class="info-item">
        <span class="info-label">PHONE INQUIRIES</span>
        <span class="info-value">+1 (416) 555-0199</span>
      </div>
      <div class="info-divider"></div>
      <div class="info-item">
        <span class="info-label">LOCATION</span>
        <span class="info-value">55 Trinity St, Toronto</span>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="services">
    <div class="services-container">
      <div class="section-header">
        <span class="section-tag">MENU</span>
        <h2>SERVICES & PRICING</h2>
        <div class="header-line"></div>
      </div>

      <div class="services-grid">
        <!-- Column 1: Haircuts -->
        <div class="services-category">
          <h3>HAIRCUTS</h3>
          <ul class="service-list">
            <li class="service-item">
              <div class="service-item-main">
                <span class="service-name">Classic Scissor Cut</span>
                <span class="service-price">$45</span>
              </div>
              <p class="service-desc">Traditional shear cut tailored to your head shape. Includes shampoo and hot lather neck shave.</p>
            </li>
            <li class="service-item">
              <div class="service-item-main">
                <span class="service-name">Modern Skin Fade</span>
                <span class="service-price">$55</span>
              </div>
              <p class="service-desc">High, mid, or low fade down to the skin with foil shaver. Finished with premium styling product.</p>
            </li>
            <li class="service-item">
              <div class="service-item-main">
                <span class="service-name">Buzz Cut & Lineup</span>
                <span class="service-price">$30</span>
              </div>
              <p class="service-desc">Single-guard clipper cut with a sharp perimeter lineup and hot towel finish.</p>
            </li>
          </ul>
        </div>

        <!-- Column 2: Shaves & Beards -->
        <div class="services-category">
          <h3>BEARD & SHAVE</h3>
          <ul class="service-list">
            <li class="service-item">
              <div class="service-item-main">
                <span class="service-name">Signature Hot Towel Shave</span>
                <span class="service-price">$50</span>
              </div>
              <p class="service-desc">Straight razor shave with pre-shave oil, hot towels, thick warm lather, and cooling aftershave balm.</p>
            </li>
            <li class="service-item">
              <div class="service-item-main">
                <span class="service-name">Beard Grooming & Shape</span>
                <span class="service-price">$35</span>
              </div>
              <p class="service-desc">Trimming, shaping, razor lineup on cheeks and neck, finished with premium beard conditioning oil.</p>
            </li>
            <li class="service-item">
              <div class="service-item-main">
                <span class="service-name">The Apex Treatment</span>
                <span class="service-price">$80</span>
              </div>
              <p class="service-desc">Our combined modern skin fade and signature beard grooming package. The complete premium experience.</p>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Lookbook Section -->
  <section id="lookbook" class="lookbook">
    <div class="lookbook-container">
      <div class="section-header">
        <span class="section-tag">CRAFT</span>
        <h2>THE LOOKBOOK</h2>
        <div class="header-line"></div>
      </div>

      <div class="lookbook-grid">
        <div class="lookbook-card">
          <img src="/images/lookbook_fade.png" alt="Clean skin fade haircut with modern pompadour top" />
          <div class="lookbook-info">
            <h4>THE MODERN POMP</h4>
            <p>High skin fade with structured top length.</p>
          </div>
        </div>

        <div class="lookbook-card highlight-card">
          <div class="highlight-content">
            <span class="quote-mark">"</span>
            <h3>PRECISION IS NOT AN ACCIDENT. IT IS THE RESULT OF KNOWLEDGE AND DELIBERATE PRACTICE.</h3>
            <span class="quote-author">— APEX PHILOSOPHY</span>
          </div>
        </div>

        <div class="lookbook-card">
          <img src="/images/lookbook_beard.png" alt="Perfectly groomed dense beard with sharp razor cheek lines" />
          <div class="lookbook-info">
            <h4>BEARD DESIGN</h4>
            <p>Razor lined cheek contour with oil conditioning.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Barbers Section -->
  <section id="barbers" class="barbers">
    <div class="barbers-container">
      <div class="section-header">
        <span class="section-tag">TEAM</span>
        <h2>MEET THE BARBERS</h2>
        <div class="header-line"></div>
      </div>

      <div class="barbers-grid">
        <!-- Barber 1 -->
        <div class="barber-card">
          <div class="barber-badge">MEMBER</div>
          <div class="barber-details">
            <h3>Marcus Vance</h3>
            <span class="barber-title">Master Barber & Founder</span>
            <div class="card-divider"></div>
            <p>Specializes in classic English shear cuts and traditional hot towel straight razor shaves. 12+ years experience.</p>
          </div>
        </div>

        <!-- Barber 2 -->
        <div class="barber-card">
          <div class="barber-badge">MEMBER</div>
          <div class="barber-details">
            <h3>Leon Chen</h3>
            <span class="barber-title">Fade Specialist</span>
            <div class="card-divider"></div>
            <p>Expert in modern skin fades, texturized crops, and creative razor patterns. Keep your lineup surgically sharp.</p>
          </div>
        </div>

        <!-- Barber 3 -->
        <div class="barber-card">
          <div class="barber-badge">MEMBER</div>
          <div class="barber-details">
            <h3>Sarah Jenkins</h3>
            <span class="barber-title">Beard Sculptor</span>
            <div class="card-divider"></div>
            <p>Dedicated to beard shaping, mustache designs, and premium skin therapy treatments. Keeps you looking polished.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Location, Booking & Contact -->
  <section id="contact" class="contact">
    <div class="contact-container">
      <div class="contact-grid">
        <div class="contact-info">
          <span class="section-tag">VISIT US</span>
          <h2>HOURS & LOCATION</h2>
          <div class="header-line left"></div>
          
          <div class="info-block">
            <h3>ADDRESS</h3>
            <p>55 Trinity St, Suite 104<br />Toronto, ON M5A 3C4</p>
          </div>

          <div class="info-block">
            <h3>HOURS</h3>
            <table class="hours-table">
              <tr>
                <td>Monday – Friday</td>
                <td>9:00 AM – 8:00 PM</td>
              </tr>
              <tr>
                <td>Saturday</td>
                <td>9:00 AM – 6:00 PM</td>
              </tr>
              <tr>
                <td>Sunday</td>
                <td>11:00 AM – 5:00 PM</td>
              </tr>
            </table>
          </div>

          <div class="info-block">
            <h3>CONTACT</h3>
            <p>Phone: +1 (416) 555-0199<br />Email: booking@apexbarber.co</p>
          </div>
        </div>

        <div class="booking-card">
          <h3>APPOINTMENT DETAILS</h3>
          <p class="booking-intro">
            We highly recommend booking an appointment ahead of time. Select your service, date, and preferred barber, then call or submit a reservation request.
          </p>
          
          <form class="booking-form" onsubmit="return false;">
            <div class="form-group">
              <label for="client-name">Full Name</label>
              <input type="text" id="client-name" name="name" required placeholder="Alex Mercer" />
            </div>
            
            <div class="form-group">
              <label for="client-phone">Phone Number</label>
              <input type="tel" id="client-phone" name="phone" required placeholder="(416) 555-0199" />
            </div>

            <div class="form-group">
              <label for="booking-service">Service Requested</label>
              <select id="booking-service" name="service">
                <option value="classic">Classic Scissor Cut - $45</option>
                <option value="fade">Modern Skin Fade - $55</option>
                <option value="shave">Signature Hot Towel Shave - $50</option>
                <option value="beard">Beard Grooming & Shape - $35</option>
                <option value="treatment">The Apex Treatment - $80</option>
              </select>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="booking-date">Date</label>
                <input type="date" id="booking-date" name="date" required />
              </div>
              <div class="form-group">
                <label for="booking-time">Time</label>
                <input type="time" id="booking-time" name="time" required />
              </div>
            </div>

            <button type="submit" class="btn btn-primary btn-full">Submit Request</button>
          </form>
          <span class="form-footnote">*Note: We will text you to confirm your booking slot.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-container">
      <p class="footer-brand">APEX BARBER CO.</p>
      <p class="footer-copy">&copy; 2026 Apex Barber Co. Static SSG layout, zero JS.</p>
    </div>
  </footer>
</Layout>

<style>
  /* Header & Navigation */
  .header {
    background-color: rgba(10, 10, 10, 0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.5rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .logo-text {
    font-size: 1.4rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    color: var(--color-text);
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }
  .nav-links a:not(.btn) {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }
  .nav-links a:not(.btn):hover {
    color: var(--color-primary);
  }

  /* Buttons */
  .btn {
    display: inline-block;
    padding: 0.85rem 1.75rem;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: var(--border-radius);
    border: 1px solid transparent;
  }
  .btn-primary {
    background-color: var(--color-primary);
    color: #0A0A0A;
  }
  .btn-primary:hover {
    background-color: var(--color-primary-hover);
  }
  .btn-outline {
    border-color: var(--color-border-light);
    color: var(--color-text);
  }
  .btn-outline:hover {
    background-color: var(--color-bg-card);
    border-color: var(--color-primary);
  }
  .btn-full {
    display: block;
    width: 100%;
    text-align: center;
  }

  /* Hero Section */
  .hero {
    height: 75vh;
    min-height: 550px;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    padding: 2rem;
  }
  .hero-container {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }
  .hero-tag {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    display: block;
  }
  .hero-title {
    font-size: clamp(2.2rem, 5vw, 4rem);
    line-height: 1.1;
    margin-bottom: 1.5rem;
    font-weight: 900;
  }
  .hero-desc {
    font-size: 1.15rem;
    max-width: 600px;
    margin: 0 auto 2.5rem auto;
    color: #C0C0C0;
  }
  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  /* Info Strip */
  .info-strip {
    background-color: var(--color-bg-alt);
    border-bottom: 1px solid var(--color-border);
    padding: 1.75rem 2rem;
  }
  .info-strip-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .info-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .info-label {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 0.1em;
  }
  .info-value {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
  }
  .info-divider {
    width: 1px;
    height: 35px;
    background-color: var(--color-border);
  }

  /* Section Header */
  .section-header {
    text-align: center;
    margin-bottom: 4.5rem;
  }
  .section-tag {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 0.25em;
    display: block;
    margin-bottom: 0.75rem;
  }
  .section-header h2 {
    font-size: 2.25rem;
    letter-spacing: 0.05em;
  }
  .header-line {
    width: 50px;
    height: 2px;
    background-color: var(--color-primary);
    margin: 1.25rem auto 0 auto;
  }
  .header-line.left {
    margin-left: 0;
  }

  /* Services Section */
  .services {
    padding: 8rem 2rem;
    background-color: var(--color-bg);
  }
  .services-container {
    max-width: 1100px;
    margin: 0 auto;
  }
  .services-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4.5rem;
  }
  .services-category h3 {
    font-size: 1.4rem;
    font-weight: 700;
    border-bottom: 1px solid var(--color-border-light);
    padding-bottom: 1rem;
    margin-bottom: 2rem;
    letter-spacing: 0.05em;
    color: var(--color-primary);
  }
  .service-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
  }
  .service-item-main {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.5rem;
  }
  .service-name {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .service-price {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-primary);
  }
  .service-desc {
    font-size: 0.9rem;
    line-height: 1.5;
  }

  /* Lookbook Section */
  .lookbook {
    padding: 8rem 2rem;
    background-color: var(--color-bg-alt);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .lookbook-container {
    max-width: 1200px;
    margin: 0 auto;
  }
  .lookbook-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 2rem;
  }
  .lookbook-card {
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    position: relative;
    transition: var(--transition-smooth);
  }
  .lookbook-card:hover {
    transform: translateY(-5px);
    border-color: var(--color-primary);
  }
  .lookbook-card img {
    width: 100%;
    height: 380px;
    object-fit: cover;
  }
  .lookbook-info {
    padding: 1.5rem;
    border-top: 1px solid var(--color-border);
  }
  .lookbook-info h4 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.25rem;
    letter-spacing: 0.05em;
  }
  .lookbook-info p {
    font-size: 0.85rem;
  }
  .highlight-card {
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-primary);
    padding: 3rem 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .highlight-content {
    text-align: center;
  }
  .quote-mark {
    font-family: var(--font-heading);
    font-size: 5rem;
    line-height: 1;
    color: var(--color-primary);
    display: block;
    margin-bottom: -1rem;
    opacity: 0.3;
  }
  .highlight-content h3 {
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.6;
    letter-spacing: 0.02em;
    color: var(--color-text);
    margin-bottom: 1.5rem;
  }
  .quote-author {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--color-primary);
  }

  /* Barbers Section */
  .barbers {
    padding: 8rem 2rem;
    background-color: var(--color-bg);
  }
  .barbers-container {
    max-width: 1100px;
    margin: 0 auto;
  }
  .barbers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
  }
  .barber-card {
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    padding: 3rem 2rem;
    position: relative;
    overflow: hidden;
    transition: var(--transition-smooth);
  }
  .barber-card:hover {
    border-color: var(--color-primary);
  }
  .barber-badge {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    font-size: 0.65rem;
    font-weight: 700;
    background-color: rgba(197, 168, 128, 0.15);
    color: var(--color-primary);
    padding: 0.25rem 0.65rem;
    border-radius: 2px;
    letter-spacing: 0.05em;
  }
  .barber-details h3 {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }
  .barber-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primary);
    letter-spacing: 0.05em;
  }
  .card-divider {
    height: 1px;
    width: 35px;
    background-color: var(--color-border-light);
    margin: 1.25rem 0;
  }
  .barber-card p {
    font-size: 0.9rem;
    line-height: 1.6;
  }

  /* Contact & Booking Section */
  .contact {
    padding: 8rem 2rem;
    background-color: var(--color-bg-alt);
    border-top: 1px solid var(--color-border);
  }
  .contact-container {
    max-width: 1100px;
    margin: 0 auto;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 5rem;
    align-items: flex-start;
  }
  .info-block {
    margin-top: 2.5rem;
  }
  .info-block h3 {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }
  .info-block p {
    font-size: 1.05rem;
    color: var(--color-text);
  }
  .contact-info .hours-table {
    width: 100%;
    border-collapse: collapse;
    max-width: 400px;
  }
  .contact-info .hours-table td {
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }
  .contact-info .hours-table tr td:last-child {
    text-align: right;
    color: var(--color-text);
    font-weight: 600;
  }

  /* Booking Form Card */
  .booking-card {
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    padding: 3.5rem;
    box-shadow: var(--shadow-lg);
  }
  .booking-card h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
  }
  .booking-intro {
    font-size: 0.9rem;
    margin-bottom: 2.25rem;
  }
  .booking-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .form-group label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-primary);
  }
  .form-group input,
  .form-group select {
    padding: 0.85rem 1rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    border: 1px solid var(--color-border);
    background-color: var(--color-bg);
    color: var(--color-text);
    border-radius: var(--border-radius);
    transition: var(--transition-smooth);
  }
  .form-group input:focus,
  .form-group select:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px rgba(197, 168, 128, 0.2);
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  .form-footnote {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    display: block;
    margin-top: 1rem;
    text-align: center;
  }

  /* Footer */
  .footer {
    background-color: #050505;
    border-top: 1px solid var(--color-border);
    padding: 3.5rem 2rem;
  }
  .footer-container {
