{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "compatibility_date": "2026-06-08",
  "compatibility_flags": ["global_fetch_strictly_public"],
  "name": "barber",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": false,
  },
  "preview_urls": false,
}
